# ─────────────────────────────────────────────
# Server
# ─────────────────────────────────────────────
PORT=3000
API_VERSION=1.0.0
NODE_ENV=development

# ─────────────────────────────────────────────
# Authentication
# Set AUTH_MODE to one of:
#   none    — No auth (open API, for development only)
#   apikey  — API key via x-api-key request header
#   token   — Bearer token (static token in TOKEN_SECRET)
#   oauth2  — OAuth 2.0 client credentials flow (built-in server)
# ─────────────────────────────────────────────
AUTH_MODE=apikey
API_KEY=my-secret-api-key
TOKEN_SECRET=my-bearer-token-secret

# OAuth 2.0 Settings (only used when AUTH_MODE=oauth2)
# JWT signing secret for access tokens
OAUTH_JWT_SECRET=change-this-to-a-random-secret
# Access token TTL in seconds (default: 3600 = 1 hour)
OAUTH_TOKEN_TTL=3600

# ─────────────────────────────────────────────
# Database
# ─────────────────────────────────────────────
# PostgreSQL connection string
# In Codespaces / docker-compose (API outside container): use localhost
#   DATABASE_URL=postgresql://api_user:api_pass@localhost:5432/multi_api_mock_server_db
# In docker-compose.full.yml (API inside container): use postgres hostname
#   DATABASE_URL=postgresql://api_user:api_pass@postgres:5432/multi_api_mock_server_db
DATABASE_URL=postgresql://api_user:api_pass@localhost:5432/multi_api_mock_server_db

# ─────────────────────────────────────────────
# Pagination
# Set PAGINATION_MODE to one of:
#   offset  — Classic page/limit (default)
#   cursor  — Cursor-based (next/previous cursors)
#   link    — Link header (RFC 5988)
# ─────────────────────────────────────────────
PAGINATION_MODE=offset
DEFAULT_PAGE_SIZE=10
MAX_PAGE_SIZE=100

# ─────────────────────────────────────────────
# Rate Limiting
# ─────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100

# ─────────────────────────────────────────────
# Error Simulation
# Set rates as decimals (0.0 = off, 0.1 = 10%, 1.0 = 100%)
# ─────────────────────────────────────────────
ERROR_RATE_500=0.0
ERROR_RATE_429=0.0
ERROR_RATE_TIMEOUT=0.0
# Timeout delay in ms (simulated slow response before hanging up)
ERROR_TIMEOUT_DELAY_MS=30000

# ─────────────────────────────────────────────
# Logging
# ─────────────────────────────────────────────
LOG_LEVEL=info
