# ─────────────────────────────────────────────
# Server
# ─────────────────────────────────────────────
PORT=3000
API_VERSION=4.0.1
NODE_ENV=development


# ─────────────────────────────────────────────
# Authentication
# Set AUTH_MODE to one of:
#   none    — No auth (open API, for development only)
#   apikey  — API key via x-api-key request header (default)
# ─────────────────────────────────────────────
AUTH_MODE=apikey
API_KEY=fhir-dev-api-key-change-me

# ─────────────────────────────────────────────
# Data
# Set DATA_MODE to one of:
#   mock     — In-memory data loaded from src/data/*.json (no DB needed)
#   postgres — PostgreSQL via pg (use DATABASE_URL below)
#
# PostgreSQL is always available via docker-compose regardless of DATA_MODE.
# ─────────────────────────────────────────────
DATA_MODE=postgres

# PostgreSQL connection string
# In Codespaces / running API natively: use "localhost"
#   DATABASE_URL=postgresql://api_user:api_pass@localhost:5432/fhir_r4_db
# When using docker-compose.full.yml: use "postgres" as hostname
#   DATABASE_URL=postgresql://api_user:api_pass@postgres:5432/fhir_r4_db
DATABASE_URL=postgresql://api_user:api_pass@localhost:5432/fhir_r4_db

# ─────────────────────────────────────────────
# Pagination
# ─────────────────────────────────────────────
DEFAULT_PAGE_SIZE=10
MAX_PAGE_SIZE=100

# ─────────────────────────────────────────────
# Rate Limiting
# ─────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=200

# ─────────────────────────────────────────────
# Logging
# ─────────────────────────────────────────────
LOG_LEVEL=info
