# =============================================================================
# DemoBench Codespace — Environment Variables
# Copy this file to .env and fill in any required values.
# cp .env.example .env
# =============================================================================

# -----------------------------------------------------------------------------
# PostgreSQL (shared instance)
# -----------------------------------------------------------------------------
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=demobench
POSTGRES_PASSWORD=demobench_pass
POSTGRES_DB=demobench

# Keycloak gets its own dedicated database on the same Postgres instance
KEYCLOAK_DB=keycloak
KEYCLOAK_DB_USER=keycloak
KEYCLOAK_DB_PASSWORD=keycloak_pass

# -----------------------------------------------------------------------------
# Dashboard (orchestrator UI)
# Port: 4500
# -----------------------------------------------------------------------------
DASHBOARD_PORT=4500

# -----------------------------------------------------------------------------
# Multi-API Mock Server
# Port: 3000
# Auth modes: none | apikey | token | oauth2
# -----------------------------------------------------------------------------
MOCK_API_PORT=3000
MOCK_API_AUTH_MODE=apikey
MOCK_API_KEY=mock-api-key-changeme
MOCK_API_TOKEN_SECRET=mock-bearer-token-changeme
MOCK_API_OAUTH_JWT_SECRET=mock-oauth-jwt-secret-changeme
MOCK_API_PAGINATION_MODE=offset
MOCK_API_ERROR_RATE_500=0.0
MOCK_API_ERROR_RATE_429=0.0
MOCK_API_ERROR_RATE_TIMEOUT=0.0
MOCK_API_DATABASE_URL=postgresql://demobench:demobench_pass@postgres:5432/demobench

# -----------------------------------------------------------------------------
# FHIR R4 API
# Port: 3001
# Data modes: postgres | mock
# -----------------------------------------------------------------------------
FHIR_API_PORT=3001
FHIR_API_KEY=fhir-api-key-changeme
FHIR_API_AUTH_MODE=apikey
FHIR_DATA_MODE=postgres
FHIR_DATABASE_URL=postgresql://demobench:demobench_pass@postgres:5432/demobench

# -----------------------------------------------------------------------------
# FHIR R4 Web App
# Port: 3002
# FHIR_WEB_API_BASE_URL: the URL the BROWSER uses to call the FHIR API.
# In Codespaces, set this to the forwarded URL of port 3001.
# Example: https://your-codespace-3001.preview.app.github.dev
# Leave blank to use relative path (only works if fhir-web and fhir-api
# share the same origin, which is NOT the case when running independently).
# -----------------------------------------------------------------------------
FHIR_WEB_PORT=3002
FHIR_WEB_API_BASE_URL=http://localhost:3001

# -----------------------------------------------------------------------------
# Metric SSE Server
# Port: 3003
# -----------------------------------------------------------------------------
METRIC_SSE_PORT=3003
METRIC_SSE_INTERVAL_MS=2000
METRIC_SSE_NOTIFICATION_PROBABILITY=0.25
METRIC_SSE_HEARTBEAT_INTERVAL_MS=15000

# -----------------------------------------------------------------------------
# US Railway Mock SSE Server
# Port: 3004
# -----------------------------------------------------------------------------
RAILWAY_SSE_PORT=3004
RAILWAY_SSE_TICK_MS=5000
RAILWAY_SSE_TRAIN_COUNT=10
RAILWAY_SSE_TIME_SCALE=60

# -----------------------------------------------------------------------------
# LiteLLM Proxy
# Port: 4000
# Add only the keys for providers you actually use.
# LITELLM_MASTER_KEY is the key clients use to call the proxy.
# -----------------------------------------------------------------------------
LITELLM_PORT=4000
LITELLM_MASTER_KEY=sk-changeme-masterkey
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
AZURE_API_KEY=
AZURE_API_BASE=
GEMINI_API_KEY=

# -----------------------------------------------------------------------------
# Open WebUI
# Port: 8081
# OPENAI_API_BASE_URL: point to LiteLLM proxy or directly to OpenAI
# -----------------------------------------------------------------------------
OPEN_WEBUI_PORT=8081
OPEN_WEBUI_OPENAI_API_BASE_URL=http://litellm:4000/v1
OPEN_WEBUI_OPENAI_API_KEY=${LITELLM_MASTER_KEY}

# -----------------------------------------------------------------------------
# Presidio (PII Detection & Anonymization)
# Ports: 5001 (anonymizer), 5002 (analyzer), 5003 (image-redactor)
# No configuration needed — uses official Microsoft Docker images.
# Note: Images are large (~2 GB). First pull takes 3–6 minutes.
# -----------------------------------------------------------------------------
PRESIDIO_ANALYZER_PORT=5002
PRESIDIO_ANONYMIZER_PORT=5001
PRESIDIO_IMAGE_REDACTOR_PORT=5003

# -----------------------------------------------------------------------------
# Keycloak
# Port: 8080
# Default admin credentials — change after first login in production.
# -----------------------------------------------------------------------------
KEYCLOAK_PORT=8080
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin

# -----------------------------------------------------------------------------
# Jaeger Distributed Tracing
# Ports: 16686 (UI), 14250 (gRPC collector), 14268 (HTTP collector)
# No configuration needed — uses official Jaeger all-in-one image.
# -----------------------------------------------------------------------------
JAEGER_UI_PORT=16686
JAEGER_GRPC_PORT=14250
JAEGER_HTTP_PORT=14268

# -----------------------------------------------------------------------------
# New Relic OpenTelemetry Collector
# Ports: 4317 (gRPC OTLP), 4318 (HTTP OTLP)
# NEW_RELIC_LICENSE_KEY is REQUIRED for this service to forward data.
# Get yours at: https://one.newrelic.com/admin-portal/api-keys/home
# Use the License Key (starts with NRAK-), not a User API key.
# -----------------------------------------------------------------------------
NEW_RELIC_OTEL_GRPC_PORT=4317
NEW_RELIC_OTEL_HTTP_PORT=4318
NEW_RELIC_LICENSE_KEY=

# -----------------------------------------------------------------------------
# SFTP Server
# Port: 3022 (internal SSH/SFTP)
# IMPORTANT: Codespaces only forward HTTP ports. To expose SFTP externally,
# you must set up an ngrok TCP tunnel manually. See README for instructions.
# -----------------------------------------------------------------------------
SFTP_PORT=3022
SFTP_USER=foo
SFTP_PASSWORD=pass
NGROK_AUTHTOKEN=

# -----------------------------------------------------------------------------
# Portainer (Docker management UI)
# Port: 9000
# -----------------------------------------------------------------------------
PORTAINER_PORT=9000
